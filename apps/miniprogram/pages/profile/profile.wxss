.input {
  border: 1rpx solid rgba(165, 196, 241, 0.26);
  border-radius: 14rpx;
  padding: 12rpx;
  margin-top: 8rpx;
  margin-bottom: 8rpx;
  color: #eaf3ff;
  background: linear-gradient(145deg, rgba(40, 54, 98, 0.74), rgba(34, 49, 92, 0.82));
}

.btn-ghost {
  margin-top: 8rpx;
}

.action-row {
  margin-top: 12rpx;
  display: flex;
  gap: 12rpx;
}

.action-btn {
  flex: 1;
}

.selector-head {
  margin-top: 6rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
}

.selector-head-company {
  margin-top: 16rpx;
}

.selector-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #ecf4ff;
}

.selector-count {
  font-size: 20rpx;
  color: #dceaff;
  border: 1rpx solid rgba(171, 201, 244, 0.34);
  border-radius: 999rpx;
  padding: 4rpx 10rpx;
  background: rgba(64, 95, 162, 0.22);
}

.watch-scroll {
  margin-top: 10rpx;
  border-radius: 14rpx;
  border: 1rpx solid rgba(151, 182, 229, 0.24);
  background: linear-gradient(165deg, rgba(22, 41, 84, 0.54), rgba(17, 33, 69, 0.62));
  padding: 8rpx 10rpx;
}

.watch-scroll-index {
  height: 300rpx;
}

.watch-scroll-company {
  height: 400rpx;
}

.watch-item {
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
  margin-top: 8rpx;
  padding: 10rpx;
  border: 1rpx solid rgba(41, 86, 110, 0.24);
  border-radius: 12rpx;
  background: rgba(35, 61, 113, 0.35);
}

.watch-item:first-child {
  margin-top: 0;
}

.watch-copy {
  min-width: 0;
  flex: 1;
}

.watch-title {
  display: block;
  font-size: 24rpx;
  color: #eaf3ff;
  font-weight: 650;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.watch-meta {
  display: block;
  margin-top: 4rpx;
  font-size: 20rpx;
  color: #aac3e0;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.watch-empty {
  margin-top: 8rpx;
  padding: 16rpx 10rpx;
  text-align: center;
  font-size: 22rpx;
  color: #9db9d4;
}

.save-btn {
  margin-top: 16rpx;
}
