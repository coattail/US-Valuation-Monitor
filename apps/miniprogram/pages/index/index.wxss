.page-wrap {
  min-height: 100%;
}

.container {
  padding-top: 16rpx;
}

.toolbar {
  margin-top: 10rpx;
}

.toolbar-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.picker-label {
  border: 1rpx solid rgba(188, 212, 255, 0.3);
  border-radius: 14rpx;
  padding: 10rpx 14rpx;
  font-size: 24rpx;
  color: #dbe9ff;
  background: linear-gradient(145deg, rgba(40, 54, 98, 0.74), rgba(34, 49, 92, 0.82));
}

.search-row {
  margin-top: 12rpx;
  display: flex;
  gap: 12rpx;
}

.search-input {
  flex: 1;
  border: 1rpx solid rgba(188, 212, 255, 0.3);
  border-radius: 14rpx;
  padding: 10rpx 14rpx;
  background: linear-gradient(145deg, rgba(40, 54, 98, 0.74), rgba(34, 49, 92, 0.82));
  color: #f0f6ff;
  font-size: 25rpx;
}

.count-hint {
  margin-top: 14rpx;
  font-size: 24rpx;
  color: #a9c3e2;
}

.btn-clear {
  min-width: 120rpx;
}

.btn-more {
  margin-top: 18rpx;
}

.empty-hint {
  margin-top: 18rpx;
  text-align: center;
}
