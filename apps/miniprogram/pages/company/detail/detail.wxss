.header-line {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.header-copy {
  min-width: 0;
  flex: 1;
}

.header-copy .panel-title {
  margin-bottom: 8rpx;
}

.header-meta {
  font-size: 24rpx;
  line-height: 1.35;
  color: #afc7e4;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.watch-btn {
  white-space: nowrap;
  border-radius: 999rpx;
  border: 1rpx solid rgba(188, 212, 255, 0.35);
  color: #dceaff;
  background: linear-gradient(145deg, rgba(40, 54, 98, 0.72), rgba(34, 49, 92, 0.8));
}

.watch-btn--compact {
  min-width: 120rpx;
  font-size: 23rpx;
  padding: 0 14rpx;
}

.watch-btn.active {
  color: #ffffff;
  border-color: rgba(226, 237, 255, 0.62);
  background: linear-gradient(148deg, rgba(72, 138, 255, 0.88), rgba(57, 178, 219, 0.82) 58%, rgba(53, 202, 188, 0.86));
}

.control-shell {
  margin-top: 14rpx;
  padding: 14rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(160, 192, 238, 0.24);
  background: linear-gradient(165deg, rgba(21, 37, 75, 0.54), rgba(16, 30, 63, 0.6));
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.control-block {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.control-divider {
  height: 1rpx;
  background: linear-gradient(90deg, rgba(130, 165, 221, 0.12), rgba(145, 179, 233, 0.3), rgba(130, 165, 221, 0.12));
}

.metric-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  flex-wrap: wrap;
  row-gap: 8rpx;
  gap: 12rpx;
}

.metric-title {
  font-size: 24rpx;
  color: #e7f2ff;
  font-weight: 700;
}

.current-tag {
  flex-shrink: 0;
  max-width: 100%;
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  color: #dbe9ff;
  border: 1rpx solid rgba(171, 201, 244, 0.35);
  background: rgba(64, 95, 162, 0.24);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.chip-scroll {
  width: 100%;
}

.chip-row {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding-right: 10rpx;
}

.range-title {
  font-size: 24rpx;
  font-weight: 700;
  color: #e7f2ff;
}

.metric-chip,
.range-chip {
  flex-shrink: 0;
  border: 1rpx solid rgba(188, 212, 255, 0.34);
  border-radius: 999rpx;
  padding: 8rpx 18rpx;
  font-size: 22rpx;
  color: #d9eaff;
  background: linear-gradient(145deg, rgba(40, 54, 98, 0.74), rgba(34, 49, 92, 0.82));
}

.metric-chip.active,
.range-chip.active {
  color: #ffffff;
  border-color: rgba(226, 237, 255, 0.62);
  background: linear-gradient(148deg, rgba(72, 138, 255, 0.88), rgba(57, 178, 219, 0.82) 58%, rgba(53, 202, 188, 0.86));
}

.range-meta {
  padding: 10rpx;
  border-radius: 12rpx;
  border: 1rpx solid rgba(151, 182, 229, 0.2);
  background: rgba(29, 49, 92, 0.35);
}

.range-meta-row {
  margin-top: 10rpx;
}

.range-meta-row:first-child {
  margin-top: 0;
}

.range-meta-label {
  font-size: 20rpx;
  color: #9cb8d8;
  display: block;
}

.range-meta-value {
  margin-top: 4rpx;
  font-size: 22rpx;
  line-height: 1.4;
  color: #e5efff;
  display: block;
  word-break: break-word;
}

.time-axis {
  margin-top: 4rpx;
  display: flex;
  justify-content: space-between;
  font-size: 20rpx;
  color: #98b6d8;
}

.row {
  display: flex;
  justify-content: space-between;
  margin-top: 10rpx;
  border-bottom: 1rpx dashed rgba(36, 77, 103, 0.2);
  padding-bottom: 8rpx;
}

.subchart-head {
  margin-top: 16rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 8rpx;
}

.subchart-title {
  font-size: 27rpx;
  font-weight: 700;
  color: #eaf3ff;
}

.loading-hint {
  text-align: center;
}
