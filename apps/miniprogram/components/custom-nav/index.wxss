.custom-nav {
  box-sizing: border-box;
  width: 100%;
  background:
    linear-gradient(180deg, rgba(11, 30, 63, 0.98), rgba(8, 21, 47, 0.98));
  border-bottom: 1rpx solid rgba(132, 168, 222, 0.2);
}

.custom-nav__inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.custom-nav__side {
  flex-shrink: 0;
}

.custom-nav__title {
  flex: 1;
  text-align: center;
  font-size: 30rpx;
  font-weight: 760;
  letter-spacing: 1rpx;
  color: #edf4ff;
}
