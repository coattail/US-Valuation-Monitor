.tabbar-shell {
  position: relative;
  box-sizing: border-box;
  width: 100%;
  padding: 10rpx 16rpx calc(env(safe-area-inset-bottom) + 10rpx);
  background:
    linear-gradient(180deg, rgba(16, 34, 71, 0.98), rgba(8, 21, 47, 0.98));
  border-top: 1rpx solid rgba(132, 168, 222, 0.22);
}

.tabbar-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 8rpx 4rpx;
}

.tab-text {
  font-size: 30rpx;
  font-weight: 600;
  letter-spacing: 0.5rpx;
}

.tab-text.is-active {
  font-weight: 760;
}
